# Variaveis de ambiente do projeto Scratch-code-
# Estas variaveis sao visiveis para qualquer pessoa usando este ambiente.
# NAO adicione segredos, tokens ou credenciais neste arquivo.

# Ambiente
NODE_ENV=development

# Diretorios de trabalho para projetos, jogos e assets
PROJECTS_DIR=./projects
GAMES_DIR=./games
ASSETS_DIR=./assets

# Ajustes de ferramentas (builds mais rapidos e silenciosos)
NPM_CONFIG_FUND=false
NPM_CONFIG_AUDIT=false
PIP_DISABLE_PIP_VERSION_CHECK=1
PYTHONDONTWRITEBYTECODE=1
